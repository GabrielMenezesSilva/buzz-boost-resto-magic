// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Perfil do restaurante
  profile      Profile?
  
  // Relacionamentos
  contacts     Contact[]
  campaigns    Campaign[]
  templates    CampaignTemplate[]
  
  @@map("users")
}

model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  restaurantName  String?  @map("restaurant_name")
  ownerName       String?  @map("owner_name")
  phone           String?
  address         String?
  description     String?
  qrCode          String   @unique @default(uuid()) @map("qr_code")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("profiles")
}

model Contact {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  name             String
  phone            String
  email            String?
  countryCode      String   @default("BR") @map("country_code")
  source           String   @default("qr_scan")
  notes            String?
  tags             String?  // JSON string array
  lastContactDate  DateTime? @map("last_contact_date")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignSends    CampaignSend[]
  
  @@map("contacts")
}

model Campaign {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  name             String
  message          String
  campaignType     String   @default("sms") @map("campaign_type")
  status           String   @default("draft")
  templateId       String?  @map("template_id")
  variables        String?  // JSON string
  filters          String?  // JSON string
  targetAudience   String?  @map("target_audience") // JSON string
  scheduledAt      DateTime? @map("scheduled_at")
  sentAt           DateTime? @map("sent_at")
  totalRecipients  Int      @default(0) @map("total_recipients")
  successfulSends  Int      @default(0) @map("successful_sends")
  failedSends      Int      @default(0) @map("failed_sends")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template         CampaignTemplate? @relation(fields: [templateId], references: [id])
  sends            CampaignSend[]
  
  @@map("campaigns")
}

model CampaignTemplate {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  message   String
  category  String   @default("general")
  variables String?  // JSON string array
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  
  @@map("campaign_templates")
}

model CampaignSend {
  id           String   @id @default(uuid())
  campaignId   String   @map("campaign_id")
  contactId    String   @map("contact_id")
  status       String   @default("pending")
  sentAt       DateTime? @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  errorMessage String?  @map("error_message")
  responseData String?  @map("response_data") // JSON string
  cost         Float    @default(0.0)
  createdAt    DateTime @default(now()) @map("created_at")
  
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  @@map("campaign_sends")
}